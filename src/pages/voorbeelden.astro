---
import Base from '../layouts/Base.astro';
---
<Base title="Voorbeelden — JARVIX" description="Concrete voorbeelden en use-cases.">
  <h1>Voorbeelden</h1>
  <p class="muted">Nog geen openbare klantcases? Dan starten we met concrete use-cases (en vervangen we ze later door echte cases).</p>

  <div class="grid">
    <div class="card" style="grid-column: span 6">
      <h2>Lead intake → CRM → opvolging</h2>
      <ul>
        <li>Formulier of e-mail lead wordt automatisch ingelezen</li>
        <li>Deduplicatie + tagging</li>
        <li>Automatische follow-up + taken</li>
      </ul>
    </div>
    <div class="card" style="grid-column: span 6">
      <h2>Support triage</h2>
      <ul>
        <li>Tickets worden geclassificeerd</li>
        <li>Urgentie + routing naar juiste team/label</li>
        <li>Samenvatting voor snelle afhandeling</li>
      </ul>
    </div>
    <div class="card" style="grid-column: span 6">
      <h2>Factuur/verwerking</h2>
      <ul>
        <li>Inkomende facturen verzamelen</li>
        <li>Gegevens extractie + controle</li>
        <li>Doorzetten naar boekhouding</li>
      </ul>
    </div>
    <div class="card" style="grid-column: span 6">
      <h2>Reporting dashboard</h2>
      <ul>
        <li>Data uit tools samenbrengen</li>
        <li>1 overzicht voor KPI’s</li>
        <li>Automatische updates</li>
      </ul>
    </div>
  </div>
</Base>
