---
import Base from '../layouts/Base.astro';
const bookingUrl = "mailto:jarvix.agent@protonmail.com?subject=Intake%20aanvraag"; // TODO: replace with Calendly booking URL
---

<Base title="JARVIX — Meer aanvragen via internet voor uw bedrijf" description="JARVIX bouwt professionele websites en automatiseringen voor NL/BE MKB. Meer aanvragen, minder gedoe. Vaste prijs, opgeleverd binnen 2–4 weken.">
  <section class="hero">
    <h1>Meer aanvragen. Minder gedoe. Een website die voor je werkt.</h1>
    <p class="muted">JARVIX bouwt websites, webapps en automatiseringen voor NL/BE MKB. Snel, duidelijk, en zonder jargon. Je koopt resultaat.</p>
    <div class="row" style="margin-top:14px">
      <a class="btn" href={bookingUrl}>Plan een gratis intake</a>
      <a class="btn secondary" href="/jarvix-promo-website/quickscan">Gratis quickscan →</a>
    </div>
  </section>

  <section class="grid" style="margin-top:10px">
    <div class="card" style="grid-column: span 6">
      <h2>Wat we doen</h2>
      <ul>
        <li><strong>Website of webshop:</strong> professioneel, mobiel en snel</li>
        <li><strong>Aanvraag- en contactformulieren:</strong> klanten kunnen je online bereiken</li>
        <li><strong>Webapps & dashboards:</strong> voor interne processen of klantenportalen</li>
        <li><strong>Automatisering:</strong> minder handmatig werk, meer tijd voor de klant</li>
      </ul>
    </div>
    <div class="card" style="grid-column: span 6">
      <h2>Waarom JARVIX?</h2>
      <ul>
        <li>✅ Vaste prijs — geen verrassingen achteraf</li>
        <li>✅ Snel opgeleverd — MVP eerst, daarna uitbreiden</li>
        <li>✅ Duidelijke communicatie — geen vakjargon</li>
        <li>✅ Onderhoud inbegrepen op maat</li>
      </ul>
      <p class="muted small" style="margin-top:10px">Werkgebied: Nederland & België. Gericht op bedrijven tot 50 medewerkers.</p>
    </div>
  </section>

  <section style="margin-top: 20px; text-align:center">
    <a class="btn secondary" href="/voorbeelden" style="margin-right:10px">Bekijk voorbeelden</a>
    <a class="btn secondary" href="/diensten">Prijzen & diensten</a>
  </section>
</Base>
