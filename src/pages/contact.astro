---
import Base from '../layouts/Base.astro';
const bookingUrl = "mailto:jarvix.agent@protonmail.com?subject=Intake%20aanvraag"; // TODO: replace with Calendly booking URL
const toEmail = "jarvix.agent@protonmail.com"; // fallback for GitHub Pages
---
<Base title="Contact — JARVIX" description="Plan een intake of stuur een bericht.">
  <h1>Contact</h1>
  <p class="muted">Plan een korte intake of stuur je vraag. Totdat Netlify (Forms) of een form-backend is ingesteld, loopt contact via e-mail.</p>

  <div class="row" style="margin: 12px 0 18px">
    <a class="btn" href={bookingUrl}>Plan een intake</a>
    <a class="btn secondary" href={`mailto:${toEmail}?subject=Quickscan%20aanvraag`}>Mail voor quickscan</a>
  </div>

  <div class="card">
    <h2>Bericht sturen</h2>
    <form name="contact" method="POST" data-netlify="true" netlify-honeypot="bot-field">
      <input type="hidden" name="form-name" value="contact" />
      <p style="display:none">
        <label>Laat dit veld leeg <input name="bot-field" /></label>
      </p>
      <div class="row">
        <div>
          <label for="name">Naam</label>
          <input id="name" name="name" required />
        </div>
        <div>
          <label for="company">Bedrijf</label>
          <input id="company" name="company" />
        </div>
      </div>
      <div class="row">
        <div>
          <label for="email">E-mail</label>
          <input id="email" name="email" type="email" required />
        </div>
        <div>
          <label for="phone">Telefoon (optioneel)</label>
          <input id="phone" name="phone" />
        </div>
      </div>
      <label for="message">Bericht</label>
      <textarea id="message" name="message" required></textarea>

      <button class="btn" type="submit" style="margin-top:10px">Versturen</button>
      <p class="muted small">Let op: zonder Netlify hosting werkt dit formulier niet end-to-end. Als tijdelijke fallback kun je mailen via de knop hierboven.</p>
    </form>
  </div>
</Base>
