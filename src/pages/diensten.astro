---
import Base from '../layouts/Base.astro';
---
<Base title="Diensten — JARVIX" description="Diensten: Build, Automate, AI, Consult.">
  <h1>Diensten</h1>
  <div class="grid">
    <div class="card" style="grid-column: span 6">
      <h2>Build</h2>
      <p class="muted">Websites, webapps, dashboards, portals en MVP’s.</p>
      <ul>
        <li>Snelle MVP + iteraties</li>
        <li>SEO & performance basics</li>
        <li>Onderhoud & uitbreidingen</li>
      </ul>
    </div>
    <div class="card" style="grid-column: span 6">
      <h2>Automate</h2>
      <p class="muted">Workflows en integraties die tijd besparen en fouten verminderen.</p>
      <ul>
        <li>n8n / Power Automate / Zapier</li>
        <li>API koppelingen</li>
        <li>E-mail & notificaties</li>
      </ul>
    </div>
    <div class="card" style="grid-column: span 6">
      <h2>AI (praktisch)</h2>
      <p class="muted">AI als onderdeel van je workflow, niet als losse gimmick.</p>
      <ul>
        <li>Ticket/lead routing</li>
        <li>Samenvattingen & classificatie</li>
        <li>Document drafting (met review)</li>
      </ul>
    </div>
    <div class="card" style="grid-column: span 6">
      <h2>Consult</h2>
      <p class="muted">Quickscan → roadmap → implementatie.</p>
      <ul>
        <li>Scope & prioritering</li>
        <li>ROI-inschatting</li>
        <li>Concrete first steps</li>
      </ul>
    </div>
  </div>
</Base>
